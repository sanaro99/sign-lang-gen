# Data — NEVER commit. ASLLRP redistribution is prohibited by its license.
# Anchored with a leading slash so ONLY the top-level corpus dir is ignored — a bare `data/`
# also matched src/aslgloss/data/ and silently kept the entire data-loader module out of git.
/data/
!/data/.gitkeep
*.faiss
*.index
*.npy

# Secrets
.env

# Private / PII — never commit. Real contributor names, emails, and roles.
docs/AUTHORS.local.md

# Source documents that contain personal names (proposal, lit-review export).
# Keep these locally; do not publish to the public remote.
*.pdf

# Runs — per-run output dirs stay local; only digestible CSVs (e.g. results/summary.csv) are committed.
results/*/
results/**/raw/
results/**/*.jsonl

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Local scratch / rendered artifacts (not source)
PROGRESS.html
scratch_baseline.log
